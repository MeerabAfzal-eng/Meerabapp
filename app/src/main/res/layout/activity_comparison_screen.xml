<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8FAFC"
    android:padding="14dp"
    android:baselineAligned="false"
    tools:context=".ComparisonScreen">

    <!-- Screen Main Title (Premium Navy Blue Dark Text) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Algorithm Comparison "
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#001F3F"
        android:gravity="center"
        android:layout_marginVertical="10dp"
        tools:ignore="HardcodedText" />

    <!-- Spinners Row for Selecting Algorithms -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginBottom="14dp"
        android:baselineAligned="false">

        <!-- Algorithm A Selector -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="6dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Algorithm A:"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#475569"
                tools:ignore="HardcodedText" />
            <Spinner
                android:id="@+id/spinnerAlgoA"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@android:drawable/btn_dropdown"
                android:contentDescription="Select First Algorithm" />
        </LinearLayout>

        <!-- Algorithm B Selector -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="6dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Algorithm B:"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#475569"
                tools:ignore="HardcodedText" />
            <Spinner
                android:id="@+id/spinnerAlgoB"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@android:drawable/btn_dropdown"
                android:contentDescription="Select Second Algorithm" />
        </LinearLayout>
    </LinearLayout>

    <!-- PANEL A: Clean White Card with Navy Blue Details -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:elevation="3dp"
        android:padding="14dp"
        android:layout_marginBottom="10dp"
        android:baselineAligned="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="8dp"
            android:baselineAligned="false">
            <TextView
                android:id="@+id/lblAlgoA"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:text="Algorithm A"
                android:textStyle="bold"
                android:textColor="#001F3F"
                android:textSize="16sp"
                tools:ignore="HardcodedText" />
            <TextView
                android:id="@+id/txtSwapsA"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.9"
                android:text="Swaps: 0"
                android:gravity="center"
                android:textColor="#334155"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />
            <TextView
                android:id="@+id/txtTimerA"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.9"
                android:text="0.00s"
                android:gravity="end"
                android:textColor="#059669"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:contentDescription="Algorithm A Bars Container">
            <LinearLayout
                android:id="@+id/containerBarsA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:orientation="horizontal"/>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- PANEL B: Clean White Card with Navy Blue Details -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:elevation="3dp"
        android:padding="14dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="16dp"
        android:baselineAligned="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="8dp"
            android:baselineAligned="false">
            <TextView
                android:id="@+id/lblAlgoB"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:text="Algorithm B"
                android:textStyle="bold"
                android:textColor="#001F3F"
                android:textSize="16sp"
                tools:ignore="HardcodedText" />
            <TextView
                android:id="@+id/txtSwapsB"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.9"
                android:text="Swaps: 0"
                android:gravity="center"
                android:textColor="#334155"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />
            <TextView
                android:id="@+id/txtTimerB"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.9"
                android:text="0.00s"
                android:gravity="end"
                android:textColor="#059669"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:contentDescription="Algorithm B Bars Container">
            <LinearLayout
                android:id="@+id/containerBarsB"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:orientation="horizontal"/>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Action Buttons Row (Premium Solid Looks) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:baselineAligned="false">
        <Button
            android:id="@+id/btnStartCompare"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Start Compare"
            android:layout_margin="4dp"
            android:padding="12dp"
            android:textStyle="bold"
            android:backgroundTint="#001F3F"
            tools:ignore="HardcodedText" />
        <Button
            android:id="@+id/btnResetCompare"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Reset"
            android:layout_margin="4dp"
            android:padding="12dp"
            android:textStyle="bold"
            android:textColor="#1E293B"
            android:backgroundTint="#E2E8F0"
            tools:ignore="HardcodedText" />
    </LinearLayout>

</LinearLayout>