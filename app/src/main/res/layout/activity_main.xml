<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sorting Algorithm Visualizer"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#001F3F"
            android:gravity="center"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="20dp" />

        <Spinner
            android:id="@+id/spinnerAlgorithm"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/spinner_background"
            android:paddingStart="16dp"
            android:paddingEnd="40dp"
            android:layout_marginBottom="16dp"
            android:spinnerMode="dropdown" />

        <EditText
            android:id="@+id/etInputNumber"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/edit_text_background"
            android:hint="Enter Number (Max 30)"
            android:textColorHint="#94A3B8"
            android:textColor="#001F3F"

            android:inputType="phone"
            android:digits="0123456789+-"

            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="16sp"
            android:layout_marginBottom="16dp"
            android:importantForAutofill="no" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btnValueAdd"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Add Value"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="#001F3F"
                android:textColor="@android:color/white"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnValueRemove"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Remove Last"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="#001F3F"
                android:textColor="@android:color/white"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:scrollbars="none"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:id="@+id/layoutBarsWrapper"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="@android:color/white"
                android:elevation="1dp"
                android:padding="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnSortNow"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Sort Now"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#001F3F"
            android:textColor="@android:color/white"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="10dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCompareScreen"
                android:layout_width="0dp"
                android:layout_height="75dp"
                android:layout_weight="1"
                android:text="📊\nCompare"
                android:textAllCaps="false"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/button_background"
                android:textColor="#001F3F"
                android:layout_margin="5dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnTakeQuiz"
                android:layout_width="0dp"
                android:layout_height="75dp"
                android:layout_weight="1"
                android:text="📝\nTake Quiz"
                android:textAllCaps="false"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/button_background"
                android:textColor="#001F3F"
                android:layout_margin="5dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnViewProgress"
                android:layout_width="0dp"
                android:layout_height="75dp"
                android:layout_weight="1"
                android:text="📈\nProgress"
                android:textAllCaps="false"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/button_background"
                android:textColor="#001F3F"
                android:layout_margin="5dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>